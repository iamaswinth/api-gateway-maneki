# Postgres (same instance as the other Maneki services in dev; own schema).
GATEWAY_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
GATEWAY_DB_SCHEMA=gateway

# Redis (new to this stack; run via docker-compose.yml for dev).
GATEWAY_REDIS_URL=redis://localhost:6379/0

# Clerk owner auth. GATEWAY_CLERK_ISSUER is the Clerk instance's issuer URL,
# used to fetch JWKS at https://{issuer}/.well-known/jwks.json.
GATEWAY_CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# Service-to-service token for the voice runtime's internal endpoint. Never
# reused for owner or widget auth.
GATEWAY_INTERNAL_TOKEN=change-me-dev-only

# LiveKit — used to mint widget tokens and verify webhook signatures.
GATEWAY_LIVEKIT_URL=wss://your-project.livekit.cloud
GATEWAY_LIVEKIT_API_KEY=
GATEWAY_LIVEKIT_API_SECRET=

# Ingestion service base URL, for authenticated forwarding.
GATEWAY_INGESTION_BASE_URL=http://localhost:8000

# Rate limiting / concurrency knobs.
GATEWAY_TOKEN_RATE_LIMIT_PER_MINUTE=30
GATEWAY_TENANT_CONFIG_CACHE_SECONDS=60
